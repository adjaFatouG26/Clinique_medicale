<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="860.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinique.controller.ConsultationController">
    <children>
        <SplitPane dividerPositions="0.4" prefHeight="600" prefWidth="860">
            <items>
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Gestion des Consultations"
                           style="-fx-font-size:16px; -fx-font-weight:bold;"/>
                    <ComboBox fx:id="patientCombo" promptText="Patient" prefWidth="200"/>
                    <ComboBox fx:id="medecinCombo" promptText="Médecin" prefWidth="200"/>
                    <ComboBox fx:id="rdvCombo" promptText="Rendez-vous" prefWidth="200"/>
                    <TextArea fx:id="diagnosticArea" promptText="Diagnostic" prefHeight="80"/>
                    <TextArea fx:id="observationsArea" promptText="Observations" prefHeight="80"/>
                    <TextArea fx:id="prescriptionArea" promptText="Prescription" prefHeight="80"/>
                    <HBox spacing="10">
                        <Button text="Enregistrer" onAction="#ajouterConsultation"
                                style="-fx-background-color:#4CAF50; -fx-text-fill:white;"/>
                    </HBox>
                    <Button text="Générer Ordonnance PDF" onAction="#genererOrdonnance"
                            style="-fx-background-color:#9C27B0; -fx-text-fill:white;"/>
                    <Label fx:id="messageLabel" style="-fx-text-fill:green;"/>
                </VBox>
                <VBox spacing="10" style="-fx-padding: 15;">
                    <TableView fx:id="consultationTable" prefHeight="500">
                        <columns>
                            <TableColumn fx:id="patientCol" text="Patient" prefWidth="150"/>
                            <TableColumn fx:id="medecinCol" text="Médecin" prefWidth="150"/>
                            <TableColumn fx:id="dateCol" text="Date" prefWidth="150"/>
                            <TableColumn fx:id="diagnosticCol" text="Diagnostic" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </items>
        </SplitPane>
    </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="300.0" prefWidth="400.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinique.controller.LoginController">
    <children>
        <VBox alignment="CENTER" spacing="15" layoutX="80" layoutY="50" prefWidth="240">
            <Label text="Clinique Médicale" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <TextField fx:id="loginField" promptText="Login"/>
            <PasswordField fx:id="passwordField" promptText="Mot de passe"/>
            <Button text="Se connecter" onAction="#seConnecter"
                    style="-fx-background-color: #2196F3; -fx-text-fill: white;"
                    prefWidth="200"/>
            <Label fx:id="messageLabel" style="-fx-text-fill: red;"/>
        </VBox>
    </children>
</AnchorPane>
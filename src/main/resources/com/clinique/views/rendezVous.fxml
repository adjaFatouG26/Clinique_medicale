<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="860.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinique.controller.RendezVousController">
    <children>
        <SplitPane dividerPositions="0.4" prefHeight="600" prefWidth="860">
            <items>
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Gestion des Rendez-vous"
                           style="-fx-font-size:16px; -fx-font-weight:bold;"/>
                    <ComboBox fx:id="patientCombo" promptText="Patient" prefWidth="200"/>
                    <ComboBox fx:id="medecinCombo" promptText="Médecin" prefWidth="200"/>
                    <DatePicker fx:id="datePicker" promptText="Date"/>
                    <ComboBox fx:id="heureCombo" promptText="Heure" prefWidth="200"/>
                    <TextField fx:id="motifField" promptText="Motif"/>
                    <HBox spacing="10">
                        <Button text="Ajouter" onAction="#ajouterRdv"
                                style="-fx-background-color:#4CAF50; -fx-text-fill:white;"/>
                        <Button text="Annuler RDV" onAction="#annulerRdv"
                                style="-fx-background-color:#F44336; -fx-text-fill:white;"/>
                    </HBox>
                    <Label fx:id="messageLabel" style="-fx-text-fill:green;"/>
                </VBox>
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Button text="RDV du jour" onAction="#afficherRdvDuJour"/>
                    <Button text="Filtrer par médecin" onAction="#filtrerParMedecin"
                            style="-fx-background-color:#673AB7; -fx-text-fill:white;"/>
                    <TableView fx:id="rdvTable" prefHeight="500">
                        <columns>
                            <TableColumn fx:id="patientCol" text="Patient" prefWidth="150"/>
                            <TableColumn fx:id="medecinCol" text="Médecin" prefWidth="150"/>
                            <TableColumn fx:id="dateCol" text="Date/Heure" prefWidth="150"/>
                            <TableColumn fx:id="statutCol" text="Statut" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </items>
        </SplitPane>
    </children>
</AnchorPane>
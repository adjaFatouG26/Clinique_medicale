<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="860.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinique.controller.FactureController">
    <children>
        <SplitPane dividerPositions="0.4" prefHeight="600" prefWidth="860">
            <items>
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Gestion des Factures"
                           style="-fx-font-size:16px; -fx-font-weight:bold;"/>
                    <ComboBox fx:id="consultationCombo" promptText="Consultation" prefWidth="200"/>
                    <TextField fx:id="montantField" promptText="Montant total"/>
                    <ComboBox fx:id="modePaiementCombo" promptText="Mode de paiement" prefWidth="200"/>
                    <ComboBox fx:id="statutPaiementCombo" promptText="Statut paiement" prefWidth="200"/>
                    <HBox spacing="10">
                        <Button text="Générer Facture" onAction="#ajouterFacture"
                                style="-fx-background-color:#4CAF50; -fx-text-fill:white;"/>
                        <Button text="Modifier" onAction="#modifierFacture"
                                style="-fx-background-color:#FF9800; -fx-text-fill:white;"/>
                    </HBox>
                    <Button text="Générer PDF" onAction="#genererPdfFacture"
                            style="-fx-background-color:#9C27B0; -fx-text-fill:white;"/>
                    <Label fx:id="messageLabel" style="-fx-text-fill:green;"/>
                </VBox>
                <VBox spacing="10" style="-fx-padding: 15;">
                    <TableView fx:id="factureTable" prefHeight="500">
                        <columns>
                            <TableColumn fx:id="consultationCol" text="Consultation" prefWidth="150"/>
                            <TableColumn fx:id="montantCol" text="Montant" prefWidth="100"/>
                            <TableColumn fx:id="modePaiementCol" text="Mode" prefWidth="100"/>
                            <TableColumn fx:id="statutCol" text="Statut" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </items>
        </SplitPane>
    </children>
</AnchorPane>
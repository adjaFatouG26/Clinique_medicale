<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="860.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinique.controller.PatientController">
    <children>
        <SplitPane dividerPositions="0.4" layoutX="0" layoutY="0"
                   prefHeight="600" prefWidth="860">
            <items>
                <!-- Formulaire gauche -->
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Gestion des Patients"
                           style="-fx-font-size:16px; -fx-font-weight:bold;"/>
                    <TextField fx:id="nomField" promptText="Nom"/>
                    <TextField fx:id="prenomField" promptText="Prénom"/>
                    <DatePicker fx:id="dateNaissancePicker" promptText="Date de naissance"/>
                    <ComboBox fx:id="sexeCombo" promptText="Sexe" prefWidth="200"/>
                    <TextField fx:id="telephoneField" promptText="Téléphone"/>
                    <TextField fx:id="adresseField" promptText="Adresse"/>
                    <ComboBox fx:id="groupeSanguinCombo" promptText="Groupe sanguin" prefWidth="200"/>
                    <TextArea fx:id="antecedentsArea" promptText="Antécédents médicaux"
                              prefHeight="80"/>
                    <HBox spacing="10">
                        <Button text="Ajouter" onAction="#ajouterPatient"
                                style="-fx-background-color:#4CAF50; -fx-text-fill:white;"/>
                        <Button text="Modifier" onAction="#modifierPatient"
                                style="-fx-background-color:#FF9800; -fx-text-fill:white;"/>
                        <Button text="Supprimer" onAction="#supprimerPatient"
                                style="-fx-background-color:#F44336; -fx-text-fill:white;"/>
                    </HBox>
                    <Label fx:id="messageLabel" style="-fx-text-fill:green;"/>
                </VBox>

                <!-- Table droite -->
                <VBox spacing="10" style="-fx-padding: 15;">
                    <HBox spacing="10">
                        <TextField fx:id="rechercheField" promptText="Rechercher..."
                                   prefWidth="200"/>
                        <Button text="Rechercher" onAction="#rechercherPatient"/>
                    </HBox>
                    <TableView fx:id="patientTable" prefHeight="500">
                        <columns>
                            <TableColumn fx:id="nomCol" text="Nom" prefWidth="120"/>
                            <TableColumn fx:id="prenomCol" text="Prénom" prefWidth="120"/>
                            <TableColumn fx:id="telCol" text="Téléphone" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </items>
        </SplitPane>
    </children>
</AnchorPane>